        112
      ],
      "id": "06a89745-434c-4523-9559-7c256c10a8a9",
      "name": "Normalize VentureBeat"
    },
    {
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "output = []\n\nraw_text = _items[0][\"json\"][\"output\"][0][\"content\"][0][\"text\"]\n\nlines = []\nfor line in raw_text.split(\"\\n\"):\n  if line.strip():\n    lines.append(line.strip())\n\nhtml_sections = \"\"\ntitle = \"\"\ncomment = \"\"\n\nfor i, line in enumerate(lines, start = 1):\n  if line.lower().startswith(\"title:\"):\n    title = line.replace(\"title:\", \"\").strip()\n  elif line.lower().startswith(\"comment:\"):\n    comment = line.replace(\"comment:\", \"\").strip()\n\n    html_sections += f\"\"\"\n      <tr>\n        <td style=\"padding:10px 25px;\">\n          <h2 style=\"margin:0 0 8px 0;font-size:16px;color:#111111;\">\n            {i//2}. {title}\n          </h2>\n          <p style=\"margin:0;font-size:13px;line-height:1.5;\">\n            {comment}\n          </p>\n        </td>\n      </tr>\n    \"\"\"\n    \n    title = \"\"\n    comment = \"\"\n\n# Template HTML\nhtml_template = f\"\"\"\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background-color:#f5f5f5;padding:20px 0;\">\n  <tr>\n    <td align=\"center\">\n      <table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background-color:#ffffff;font-family:Arial,Helvetica,sans-serif;color:#222222;\">\n        <tr>\n          <td style=\"padding:20px 25px 10px 25px;border-bottom:1px solid #eeeeee;\">\n            <h1 style=\"margin:0;font-size:22px;font-weight:bold;color:#111111;\">\n              Weekly Digest – AI & Automation\n            </h1>\n            <p style=\"margin:10px 0 0 0;font-size:13px;color:#555555;\">\n              Here are 5 key insights from recent headlines.\n            </p>\n          </td>\n        </tr>\n        {html_sections}\n      </table>\n    </td>\n  </tr>\n</table>\n\"\"\"\n\noutput.append({\"json\": {\"html\": html_template}})\nreturn output"
      },
