      "parameters": {
        "language": "pythonNative",
        "pythonCode": "output = []\n\nfor article in _items[0][\"json\"][\"guardrailsInput\"]:\n  normalized = {\n    \"title\": article.get(\"title\")\n    #\"url\": article.get(\"url\"), No necessary\n    #\"source\": article.get(\"source\"), No necessary\n    #\"publishedAt\": article.get(\"publishedAt\") No necessary\n  }\n\n  output.append({\"json\": normalized})\n\nreturn output"
      },
      "id": "2e478ed0-da62-41c8-bcf6-684f8703d410",
      "name": "Normalize TensorFeed",
      "type": "n8n-nodes-base.code",
