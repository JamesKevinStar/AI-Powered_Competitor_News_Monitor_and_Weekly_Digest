    },
    {
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "output = []\n\nfor item in _items[1:]:\n\n  html_content = item[\"json\"][\"guardrailsInput\"]\n  \n  start_title = html_content.find(\"<p>\")\n  end_title = html_content.find(\"</p>\", start_title)\n  \n  if start_title != -1 and end_title != -1:\n    title = html_content[start_title+3:end_title].strip()\n  else:\n    title = \"No title\"\n\n  normalized = {\n    \"title\": title\n  }\n\n  output.append({\"json\": normalized})\n\nreturn output"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
